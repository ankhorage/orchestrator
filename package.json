{
  "name": "@ankhorage/orchestrator",
  "version": "0.1.2",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ankhorage/orchestrator.git"
  },
  "homepage": "https://github.com/ankhorage/orchestrator#readme",
  "bugs": {
    "url": "https://github.com/ankhorage/orchestrator/issues"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && bun x tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "test": "bun test",
    "knip": "bunx knip",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@ankhorage/devtools": "^1.0.1",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "knip": "^5.88.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.13",
  "publishConfig": {
    "access": "public"
  }
}
